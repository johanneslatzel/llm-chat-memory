{
    "name": "@johannes.latzel/llm-chat-memory",
    "version": "0.1.3",
    "description": "Memory tools for the llm-chat ecosystem",
    "license": "MIT",
    "files": [
        "dist/",
        "README.md",
        "LICENSE"
    ],
    "author": "Johannes B. Latzel",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/johanneslatzel/llm-chat-memory.git"
    },
    "bugs": {
        "url": "https://github.com/johanneslatzel/llm-chat-memory/issues"
    },
    "homepage": "https://github.com/johanneslatzel/llm-chat-memory#readme",
    "keywords": [
        "llm",
        "chat",
        "memory",
        "tool"
    ],
    "engines": {
        "node": ">=18"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "prebuild": "rm -rf dist",
        "build": "tsc -p tsconfig.build.json",
        "verify": "tsc --noEmit && eslint . --max-warnings 0 && LLM_CHAT_MEMORY_RUN_INTEGRATION_TESTS=true vitest run --coverage",
        "lint": "eslint . --max-warnings 0",
        "format": "prettier --write src",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:integration": "vitest run tests/integration/",
        "test:integration:all": "LLM_CHAT_MEMORY_RUN_INTEGRATION_TESTS=true vitest run tests/integration/",
        "clean:pack": "rm -rf node_modules dist/ package-lock.json && npm cache clean --force && npm install && npm run verify && npm run build && npm pack",
        "clean:install": "rm -rf node_modules dist/ package-lock.json && npm cache clean --force && npm install && npm run verify",
        "docs": "docker run --rm -it -p 8000:8000 -v $PWD:/docs squidfunk/mkdocs-material",
        "prepare": "husky"
    },
    "publishConfig": {
        "access": "public"
    },
    "lint-staged": {
        "src/**/*.ts": [
            "prettier --write",
            "eslint --max-warnings 0 --no-warn-ignored",
            "vitest related --run"
        ]
    },
    "dependencies": {
        "@huggingface/transformers": "^4.2.0",
        "@johannes.latzel/llm-chat": "^0.6.0",
        "@johannes.latzel/pagerank": "^1.0.0",
        "async-mutex": "^0.5.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.24.0",
        "@types/node": "^22.14.1",
        "@typescript-eslint/eslint-plugin": "^8.60.0",
        "@typescript-eslint/parser": "^8.60.0",
        "@vitest/coverage-v8": "^4.1.8",
        "eslint": "^9.24.0",
        "eslint-config-prettier": "^10.1.2",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.1",
        "prettier": "^3.5.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    }
}
