# LLM Chat Memory — Configuration (example reference)
# Copy to .env and fill in your values.

# Directory containing memory JSON files (default: './memories')
# LLM_CHAT_MEMORY_DIR=./memories

# Max memories to inject per message (default: 2)
# LLM_CHAT_MEMORY_MAX_INJECT_PER_MESSAGE=2

# Cumulative cap for the entire send-loop cycle (default: 5)
# LLM_CHAT_MEMORY_MAX_INJECT_PER_SEND_LOOP=5

# Hugging Face model ID for local embedding generation (default: 'Xenova/all-MiniLM-L6-v2')
# LLM_CHAT_MEMORY_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
